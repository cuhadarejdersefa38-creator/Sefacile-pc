---
/* Gabarit HTML de base — utilisé par toutes les pages */
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Sefacile PC, spécialiste du montage PC Gaming et Workstation 3D sur-mesure en Isère. Devis gratuit, livraison en main propre.",
} = Astro.props;

const siteName    = "Sefacile PC";
const siteUrl     = "https://sefacile-pc.fr";
const fullTitle   = title === siteName ? title : title;
const pageUrl     = new URL(Astro.url.pathname, siteUrl).toString();

/* Données structurées Schema.org — LocalBusiness */
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Sefacile PC",
  "description": "Montage PC Gaming et Workstation 3D sur-mesure en Isère.",
  "url": siteUrl,
  "telephone": "+33474555657",
  "email": "contact.sefacile@gmail.com",
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Isère"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Corbelin",
    "addressRegion": "Isère",
    "addressCountry": "FR"
  },
  "priceRange": "€€",
  "knowsAbout": ["PC Gaming", "Workstation 3D", "Montage PC", "Composants informatiques"]
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph — partages sur réseaux sociaux -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={pageUrl} />
    <meta property="og:locale"      content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- Polices : Inter via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Données structurées Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <title>{fullTitle}</title>
  </head>

  <body>
    <slot />

    <!-- Bouton WhatsApp flottant — visible mobile et tablette uniquement -->
    <a
      href="https://wa.me/33474555657"
      class="whatsapp-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Discutons sur WhatsApp !"
    >
      <!-- Icône WhatsApp SVG -->
      <svg class="whatsapp-float__icone" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      <span class="whatsapp-float__tooltip">Discutons sur WhatsApp !</span>
    </a>
  </body>
</html>

<style is:global>
  /* =====================
     Variables CSS
  ===================== */
  :root {
    --couleur-fond: #0a0a0a;
    --couleur-surface: #111111;
    --couleur-surface-2: #1a1a1a;
    --couleur-rouge: #0dd3b2;
    --couleur-rouge-hover: #1aebc9;
    --couleur-texte: #ffffff;
    --couleur-texte-secondaire: #a0a0a0;
    --couleur-bordure: #2a2a2a;

    --police: "Inter", system-ui, -apple-system, sans-serif;

    --rayon: 6px;
    --rayon-grand: 12px;

    --ombre: 0 4px 20px rgba(0, 0, 0, 0.4);
    --ombre-rouge: 0 0 20px rgba(13, 211, 178, 0.25);

    --largeur-max: 1200px;
    --padding-section: 5rem 1.5rem;
  }

  /* =====================
     Reset de base
  ===================== */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--police);
    background-color: var(--couleur-fond);
    color: var(--couleur-texte);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* =====================
     Typographie globale
  ===================== */
  h1, h2, h3, h4, h5, h6 {
    line-height: 1.2;
    font-weight: 700;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* =====================
     Classe utilitaire : conteneur centré
  ===================== */
  .conteneur {
    max-width: var(--largeur-max);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* =====================
     Boutons réutilisables
  ===================== */
  .btn-principal {
    display: inline-block;
    background-color: var(--couleur-rouge);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 2rem;
    border-radius: var(--rayon);
    border: none;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.1s;
  }

  .btn-principal:hover {
    background-color: var(--couleur-rouge-hover);
    transform: translateY(-1px);
  }

  .btn-secondaire {
    display: inline-block;
    background-color: transparent;
    color: var(--couleur-texte);
    font-weight: 600;
    font-size: 1rem;
    padding: 0.85rem 2rem;
    border-radius: var(--rayon);
    border: 2px solid var(--couleur-bordure);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondaire:hover {
    border-color: var(--couleur-rouge);
    color: var(--couleur-rouge);
  }

  /* =====================
     Bouton WhatsApp flottant
  ===================== */
  .whatsapp-float {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    width: 56px;
    height: 56px;
    background-color: #25d366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.4);
    animation: whatsapp-pulse 2.5s ease-in-out infinite;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .whatsapp-float:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.55);
    animation: none;
  }

  .whatsapp-float__icone {
    width: 30px;
    height: 30px;
    fill: #fff;
    flex-shrink: 0;
  }

  /* Tooltip */
  .whatsapp-float__tooltip {
    position: absolute;
    right: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    background-color: #1a1a1a;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .whatsapp-float__tooltip::after {
    content: "";
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: #1a1a1a;
  }

  .whatsapp-float:hover .whatsapp-float__tooltip {
    opacity: 1;
  }

  @keyframes whatsapp-pulse {
    0%, 100% { box-shadow: 0 4px 16px rgba(37, 211, 102, 0.4); }
    50%       { box-shadow: 0 4px 28px rgba(37, 211, 102, 0.7); }
  }

  /* Visible sur tous les appareils */
</style>
