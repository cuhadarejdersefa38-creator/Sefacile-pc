---
/* Page Réalisations — bientôt disponible */
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Réalisations | Sefacile PC — Montage PC Isère"
  description="Découvrez bientôt les réalisations de Sefacile PC — builds Gaming et Workstation montés à Corbelin, en Isère."
>
  <Header />

  <main>
    <section class="bientot" aria-labelledby="titreBientot">
      <div class="conteneur bientot__inner">

        <!-- Illustration boîtier PC animé -->
        <div class="bientot__visuel" aria-hidden="true">
          <div class="tour">
            <div class="tour__facade">
              <div class="tour__vitre">
                <div class="tour__lueur"></div>
                <div class="tour__gpu"></div>
                <div class="tour__ram"></div>
                <div class="tour__ram tour__ram--2"></div>
              </div>
              <div class="tour__power"></div>
              <div class="tour__logo">⚡</div>
            </div>
            <div class="tour__cable tour__cable--1"></div>
            <div class="tour__cable tour__cable--2"></div>
          </div>
          <div class="bientot__badge">
            <span aria-hidden="true">🔧</span> En cours d'installation
          </div>
        </div>

        <!-- Texte principal -->
        <div class="bientot__texte">
          <h1 class="bientot__titre" id="titreBientot">Réalisations</h1>

          <p class="bientot__message">
            Notre atelier est en cours d'installation à Corbelin —
            les premières photos de builds arrivent très bientôt&nbsp;!
          </p>

          <p class="bientot__sous-message">
            En attendant, contactez-nous pour discuter de votre projet,
            nous serons ravis de vous accompagner.
          </p>

          <a href="/contact" class="btn-principal bientot__cta">
            Discutons de votre projet
          </a>

          <!-- Aperçu de ce qui arrive -->
          <div class="bientot__apercu">
            <p class="apercu__label">À venir dans la galerie :</p>
            <ul class="apercu__liste">
              <li><span aria-hidden="true">🎮</span> Builds Gaming — 1080p, 1440p, 4K</li>
              <li><span aria-hidden="true">🖥️</span> Workstations 3D — Blender, DaVinci, CAO</li>
              <li><span aria-hidden="true">📸</span> Photos avant/après montage</li>
            </ul>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>


<style>
  /* =====================
     Section principale
  ===================== */
  .bientot {
    min-height: calc(100vh - 88px);
    display: flex;
    align-items: center;
    padding: var(--padding-section);
    background:
      radial-gradient(ellipse 55% 45% at 80% 50%, rgba(13, 211, 178, 0.06) 0%, transparent 70%),
      var(--couleur-fond);
  }

  .bientot__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5rem;
    text-align: center;
  }

  /* =====================
     Illustration boîtier PC
  ===================== */
  .bientot__visuel {
    position: relative;
    flex-shrink: 0;
  }

  .tour {
    position: relative;
    width: 140px;
    margin-inline: auto;
  }

  .tour__facade {
    width: 140px;
    height: 220px;
    background: linear-gradient(160deg, #1e1e1e 0%, #111 100%);
    border: 2px solid #2a2a2a;
    border-radius: 10px 10px 6px 6px;
    position: relative;
    overflow: hidden;
    box-shadow:
      0 0 30px rgba(13, 211, 178, 0.15),
      inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .tour__vitre {
    position: absolute;
    top: 18px;
    left: 10px;
    right: 10px;
    bottom: 40px;
    background: rgba(0,0,0,0.6);
    border: 1px solid #333;
    border-radius: 4px;
    overflow: hidden;
  }

  .tour__lueur {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(13, 211, 178, 0.18) 0%, transparent 70%);
    animation: lueur-pulse 2.8s ease-in-out infinite;
  }

  @keyframes lueur-pulse {
    0%, 100% { opacity: 0.5; }
    50%       { opacity: 1; }
  }

  .tour__gpu {
    position: absolute;
    bottom: 18px;
    left: 8px;
    right: 8px;
    height: 36px;
    background: linear-gradient(90deg, #252525, #1a1a1a);
    border: 1px solid #383838;
    border-radius: 3px;
    box-shadow: 0 0 8px rgba(13, 211, 178, 0.2);
  }

  .tour__gpu::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 6px;
    right: 6px;
    height: 3px;
    background: linear-gradient(90deg, var(--couleur-rouge), transparent);
    border-radius: 2px;
    opacity: 0.7;
  }

  .tour__ram {
    position: absolute;
    top: 10px;
    left: 12px;
    width: 8px;
    height: 50px;
    background: linear-gradient(180deg, #2a2a2a, #1a1a1a);
    border: 1px solid #333;
    border-radius: 2px;
  }

  .tour__ram::after {
    content: "";
    position: absolute;
    top: 4px;
    left: 1px;
    right: 1px;
    height: 28px;
    background: linear-gradient(180deg, rgba(13,211,178,0.6), rgba(13,211,178,0.1));
    border-radius: 1px;
    animation: ram-glow 2.8s ease-in-out infinite;
  }

  @keyframes ram-glow {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }

  .tour__ram--2 {
    left: 24px;
  }

  .tour__ram--2::after {
    animation-delay: 0.4s;
  }

  .tour__power {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--couleur-rouge);
    box-shadow: 0 0 8px rgba(13, 211, 178, 0.8);
    animation: power-blink 3s ease-in-out infinite;
  }

  @keyframes power-blink {
    0%, 90%, 100% { opacity: 1; }
    95%           { opacity: 0.2; }
  }

  .tour__logo {
    position: absolute;
    bottom: 10px;
    left: 14px;
    font-size: 0.75rem;
    opacity: 0.4;
  }

  .tour__cable {
    position: absolute;
    bottom: -16px;
    width: 3px;
    height: 20px;
    background: linear-gradient(180deg, #333, transparent);
    border-radius: 2px;
  }

  .tour__cable--1 { left: 30px; }
  .tour__cable--2 { left: 50px; }

  .bientot__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.5rem;
    background-color: rgba(13, 211, 178, 0.08);
    border: 1px solid rgba(13, 211, 178, 0.25);
    color: var(--couleur-rouge);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
  }

  /* =====================
     Texte
  ===================== */
  .bientot__titre {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .bientot__message {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.7;
    max-width: 48ch;
    margin-inline: auto;
    margin-bottom: 1rem;
  }

  .bientot__sous-message {
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.7;
    max-width: 44ch;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .bientot__cta {
    font-size: 1rem;
    padding: 0.95rem 2.25rem;
    margin-bottom: 2.5rem;
    display: inline-block;
  }

  /* =====================
     Aperçu à venir
  ===================== */
  .bientot__apercu {
    background-color: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
    padding: 1.25rem 1.75rem;
    display: inline-block;
    text-align: left;
  }

  .apercu__label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--couleur-texte-secondaire);
    margin-bottom: 0.75rem;
  }

  .apercu__liste {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .apercu__liste li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: var(--couleur-texte-secondaire);
  }

  /* =====================
     Desktop (≥ 900px)
  ===================== */
  @media (min-width: 900px) {
    .bientot__inner {
      flex-direction: row;
      text-align: left;
      justify-content: center;
      align-items: center;
    }

    .bientot__message,
    .bientot__sous-message {
      margin-inline: 0;
    }
  }
</style>
