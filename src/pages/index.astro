---
/* Page Accueil — Story 2.1 */
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Montage PC Gaming Isère | Sefacile PC"
  description="Sefacile PC à Corbelin (Isère), spécialiste du montage PC Gaming et Workstation 3D sur-mesure. Devis gratuit, livraison en main propre."
>
  <Header />

  <main>

    <!-- ================================
         1. HERO
    ================================= -->
    <section class="hero" aria-label="Introduction">
      <div class="conteneur hero__inner">

        <div class="hero__contenu">
          <!-- Badge localisation -->
          <span class="hero__badge">
            <span aria-hidden="true">📍</span> Isère (38) — Grenoble · Voiron · Bourgoin
          </span>

          <h1 class="hero__titre">
            Votre PC sur-mesure<br />
            <span class="accent">en Isère</span>
          </h1>

          <p class="hero__sous-titre">
            PC Gaming haute performance ou Workstation 3D professionnelle —
            je sélectionne la config idéale, tu achètes tes pièces au meilleur prix,
            je monte et teste tout.
          </p>

          <div class="hero__boutons">
            <a href="/contact" class="btn-principal">
              Devis gratuit
            </a>
            <a href="/realisations" class="btn-secondaire">
              Voir les réalisations
            </a>
          </div>
        </div>

        <!-- Illustration décorative -->
        <div class="hero__visuel" aria-hidden="true">
          <div class="hero__pc">
            <div class="pc__ecran">
              <div class="pc__lueur"></div>
              <span class="pc__logo">⚡</span>
            </div>
            <div class="pc__pied"></div>
            <div class="pc__base"></div>
          </div>
        </div>

      </div>

      <!-- Vague décorative en bas du hero -->
      <div class="hero__vague" aria-hidden="true"></div>
    </section>


    <!-- ================================
         2. SERVICES
    ================================= -->
    <section class="services" aria-labelledby="titreServices">
      <div class="conteneur">

        <div class="section__entete">
          <h2 class="section__titre" id="titreServices">Ce que je propose</h2>
          <p class="section__sous-titre">
            Du gaming au rendu 3D professionnel, je m'adapte à votre projet.
          </p>
        </div>

        <div class="services__grille">

          <!-- Carte 1 : PC Gaming — prestation principale -->
          <article class="carte carte--mis-en-avant carte--principale">
            <div class="carte__badge-top">Notre spécialité</div>
            <div class="carte__icone" aria-hidden="true">🎮</div>
            <h3 class="carte__titre">PC Gaming</h3>
            <p class="carte__texte">
              Du 1080p fluide au 4K ultra — builds optimisés pour chaque budget,
              de 800 € à 2 500 €. Je sélectionne tes composants, tu les commandes,
              je monte et teste. FPS maximum, câblage propre.
            </p>
            <a href="/services#gaming" class="carte__lien">
              En savoir plus <span aria-hidden="true">→</span>
            </a>
          </article>

          <!-- Carte 2 : Workstation 3D -->
          <article class="carte">
            <div class="carte__icone" aria-hidden="true">🖥️</div>
            <h3 class="carte__titre">Workstation 3D</h3>
            <p class="carte__texte">
              Blender, Cinema 4D, AutoCAD — stations de travail puissantes
              pour les créatifs et professionnels 3D, de 1 500 € à 5 000 €+.
            </p>
            <a href="/services#workstation" class="carte__lien">
              En savoir plus <span aria-hidden="true">→</span>
            </a>
          </article>

          <!-- Carte 3 : Conseil & Devis -->
          <article class="carte">
            <div class="carte__icone" aria-hidden="true">💬</div>
            <h3 class="carte__titre">Conseil & Devis</h3>
            <p class="carte__texte">
              Pas sûr de ce dont tu as besoin ? Je te guide gratuitement
              pour choisir la config idéale et acheter tes pièces au meilleur prix.
            </p>
            <a href="/contact" class="carte__lien">
              Demander un conseil <span aria-hidden="true">→</span>
            </a>
          </article>

        </div>
      </div>
    </section>


    <!-- ================================
         3. COMMENT ÇA MARCHE
    ================================= -->
    <section class="process" aria-labelledby="titreProcess">
      <div class="conteneur">

        <div class="section__entete">
          <h2 class="section__titre" id="titreProcess">Comment ça marche ?</h2>
          <p class="section__sous-titre">
            Simple, transparent, sans mauvaise surprise.
          </p>
        </div>

        <ol class="process__etapes">

          <li class="process__etape">
            <div class="process__numero" aria-hidden="true">1</div>
            <div class="process__contenu">
              <h3 class="process__titre">On discute de ta config</h3>
              <p class="process__texte">
                Tu m'envoies ton budget ou tes idées, je valide et optimise
                ta sélection de composants pour éviter toute erreur de compatibilité.
              </p>
            </div>
          </li>

          <li class="process__etape">
            <div class="process__numero" aria-hidden="true">2</div>
            <div class="process__contenu">
              <h3 class="process__titre">Tu achètes tes pièces</h3>
              <p class="process__texte">
                Une fois la config validée, tu commandes tes composants où tu veux
                au meilleur prix. Je peux te guider vers les meilleures offres.
              </p>
            </div>
          </li>

          <li class="process__etape">
            <div class="process__numero" aria-hidden="true">3</div>
            <div class="process__contenu">
              <h3 class="process__titre">Je monte ton PC</h3>
              <p class="process__texte">
                Tu déposes tes pièces à l'atelier à Corbelin, je monte, teste
                avec OCCT et te livre ton PC clé en main en Isère.
              </p>
            </div>
          </li>

        </ol>
      </div>
    </section>


    <!-- ================================
         4. POINTS FORTS
    ================================= -->
    <section class="points-forts" aria-labelledby="titrePointsForts">
      <div class="conteneur">

        <div class="section__entete">
          <h2 class="section__titre" id="titrePointsForts">Pourquoi me choisir ?</h2>
        </div>

        <ul class="points-forts__grille">

          <li class="point">
            <div class="point__icone" aria-hidden="true">📍</div>
            <h3 class="point__titre">Basé en Isère</h3>
            <p class="point__texte">
              Intervention à domicile ou remise en main propre à Grenoble,
              Voiron, Bourgoin-Jallieu et alentours.
            </p>
          </li>

          <li class="point">
            <div class="point__icone" aria-hidden="true">🛡️</div>
            <h3 class="point__titre">Montage soigné et testé</h3>
            <p class="point__texte">
              Câble management propre, tests de stabilité 24 h.
              Tu achètes tes composants en direct — garantie constructeur à ton nom.
            </p>
          </li>

          <li class="point">
            <div class="point__icone" aria-hidden="true">🔧</div>
            <h3 class="point__titre">100 % sur-mesure</h3>
            <p class="point__texte">
              Chaque PC est assemblé selon vos besoins précis,
              votre budget et vos logiciels.
            </p>
          </li>

          <li class="point">
            <div class="point__icone" aria-hidden="true">⚡</div>
            <h3 class="point__titre">Passion & expertise</h3>
            <p class="point__texte">
              Auto-entrepreneur passionné par le hardware,
              je suis au courant des dernières sorties et des meilleurs rapports qualité/prix.
            </p>
          </li>

        </ul>
      </div>
    </section>


    <!-- ================================
         4. AVIS CLIENTS
    ================================= -->
    <section class="avis" aria-labelledby="titreAvis">
      <div class="conteneur">

        <div class="section__entete">
          <h2 class="section__titre" id="titreAvis">Ce que disent nos clients</h2>
          <p class="section__sous-titre">Les avis sont vérifiés par Google</p>
        </div>

        <div class="avis__contenu">

          <!-- Logo Google + étoiles -->
          <div class="avis__google">
            <!-- Logo Google SVG -->
            <svg class="avis__google-logo" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Google" role="img">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <!-- Étoiles -->
            <div class="avis__etoiles" aria-label="5 étoiles">
              <span aria-hidden="true">★★★★★</span>
            </div>
          </div>

          <!-- Message central -->
          <p class="avis__message">
            Sefacile PC vient de lancer son activité —<br />
            <strong>soyez parmi les premiers à partager votre expérience !</strong>
          </p>

          <!-- Bouton avis Google -->
          <!-- Lien Google Business configuré -->
          <a
            href="https://search.google.com/local/writereview?placeid=13322509480999268283"
            class="btn-principal avis__btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            Laisser un avis Google
          </a>

          <!-- Mention d'encouragement -->
          <p class="avis__encouragement">
            Vous avez déjà fait appel à Sefacile PC ? Votre avis aide d'autres clients
            à nous trouver et nous aide à grandir. Merci !
          </p>

        </div>
      </div>
    </section>


    <!-- ================================
         6. CTA FINAL
    ================================= -->
    <section class="cta-final" aria-labelledby="titreCtaFinal">
      <div class="conteneur cta-final__inner">
        <div class="cta-final__texte">
          <h2 class="cta-final__titre" id="titreCtaFinal">
            Prêt à construire votre PC idéal&nbsp;?
          </h2>
          <p class="cta-final__sous-titre">
            Décrivez-moi votre projet — je vous réponds sous 24 h avec un devis personnalisé, sans engagement.
          </p>
        </div>
        <div class="cta-final__action">
          <a href="/contact" class="btn-principal cta-final__btn">
            Demander un devis gratuit
          </a>
          <!-- Appel direct sur mobile -->
          <a href="tel:0474555657" class="cta-final__tel">
            <span aria-hidden="true">📞</span> Ou appelez directement
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>


<style>
  /* =====================
     Accent rouge partagé
  ===================== */
  .accent {
    color: var(--couleur-rouge);
  }

  /* =====================
     En-têtes de section
  ===================== */
  .section__entete {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section__titre {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 0.75rem;
  }

  .section__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: 1rem;
    max-width: 52ch;
    margin-inline: auto;
  }


  /* =====================
     1. HERO
  ===================== */
  .hero {
    position: relative;
    padding: 4rem 0 6rem;
    background:
      radial-gradient(ellipse 60% 50% at 70% 40%, rgba(13, 211, 178, 0.08) 0%, transparent 70%),
      var(--couleur-fond);
    overflow: hidden;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--couleur-rouge);
    background-color: rgba(13, 211, 178, 0.1);
    border: 1px solid rgba(13, 211, 178, 0.25);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* Titre principal */
  .hero__titre {
    font-size: clamp(2.2rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 52ch;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero__boutons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* Illustration PC */
  .hero__visuel {
    flex-shrink: 0;
  }

  .hero__pc {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .pc__ecran {
    width: 180px;
    height: 120px;
    background: var(--couleur-surface-2);
    border: 2px solid var(--couleur-bordure);
    border-radius: 8px;
    display: grid;
    place-items: center;
    position: relative;
    overflow: hidden;
    box-shadow: var(--ombre-rouge);
  }

  .pc__lueur {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(13, 211, 178, 0.15), transparent 70%);
    animation: pulse 3s ease-in-out infinite;
  }

  .pc__logo {
    font-size: 3rem;
    position: relative;
    z-index: 1;
  }

  .pc__pied {
    width: 40px;
    height: 8px;
    background: var(--couleur-surface-2);
    border: 2px solid var(--couleur-bordure);
    border-top: none;
  }

  .pc__base {
    width: 100px;
    height: 6px;
    background: var(--couleur-surface-2);
    border: 2px solid var(--couleur-bordure);
    border-radius: 3px;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; }
    50%       { opacity: 1; }
  }

  /* Vague décorative */
  .hero__vague {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--couleur-surface);
    clip-path: ellipse(55% 100% at 50% 100%);
  }


  /* =====================
     2. SERVICES
  ===================== */
  .services {
    background-color: var(--couleur-surface);
    padding: var(--padding-section);
  }

  .services__grille {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* Carte de service */
  .carte {
    position: relative;
    background-color: var(--couleur-surface-2);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
    padding: 2rem 1.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .carte:hover {
    border-color: rgba(13, 211, 178, 0.4);
    transform: translateY(-3px);
  }

  /* Carte mise en avant */
  .carte--mis-en-avant {
    border-color: rgba(13, 211, 178, 0.5);
    box-shadow: var(--ombre-rouge);
  }

  .carte__badge-top {
    position: absolute;
    top: -12px;
    left: 1.75rem;
    background-color: var(--couleur-rouge);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .carte__icone {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .carte__titre {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .carte__texte {
    color: var(--couleur-texte-secondaire);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .carte__lien {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--couleur-rouge);
    transition: gap 0.2s;
  }

  .carte__lien:hover {
    gap: 0.6rem;
  }


  /* =====================
     3. COMMENT ÇA MARCHE
  ===================== */
  .process {
    padding: var(--padding-section);
    background-color: var(--couleur-fond);
    border-top: 1px solid var(--couleur-bordure);
  }

  .process__etapes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 720px;
    margin-inline: auto;
  }

  .process__etape {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .process__numero {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background-color: var(--couleur-rouge);
    color: #fff;
    font-size: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 16px rgba(13, 211, 178, 0.3);
  }

  .process__titre {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .process__texte {
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.65;
  }

  @media (min-width: 760px) {
    .process__etapes {
      flex-direction: row;
      gap: 1rem;
      max-width: 100%;
    }

    .process__etape {
      flex: 1;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }
  }

  /* =====================
     4. POINTS FORTS
  ===================== */
  .points-forts {
    padding: var(--padding-section);
    background-color: var(--couleur-fond);
  }

  .points-forts__grille {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .point {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 1.5rem;
    background-color: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
  }

  .point__icone {
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
  }

  .point__titre {
    font-size: 1rem;
    font-weight: 700;
  }

  .point__texte {
    color: var(--couleur-texte-secondaire);
    font-size: 0.875rem;
    line-height: 1.6;
  }


  /* =====================
     4. AVIS CLIENTS
  ===================== */
  .avis {
    padding: var(--padding-section);
    background-color: var(--couleur-surface);
    border-top: 1px solid var(--couleur-bordure);
  }

  .avis__contenu {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    max-width: 520px;
    margin-inline: auto;
  }

  .avis__google {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .avis__google-logo {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .avis__etoiles {
    font-size: 1.75rem;
    color: #ffd700;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .avis__message {
    font-size: 1.05rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.7;
  }

  .avis__message strong {
    color: var(--couleur-texte);
  }

  .avis__btn {
    font-size: 1rem;
    padding: 0.9rem 2rem;
  }

  .avis__encouragement {
    font-size: 0.85rem;
    color: var(--couleur-texte-secondaire);
    background-color: var(--couleur-surface-2);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
    padding: 1rem 1.25rem;
    line-height: 1.6;
    max-width: 44ch;
  }

  /* =====================
     5. CTA FINAL
  ===================== */
  .cta-final {
    background:
      linear-gradient(135deg, rgba(13, 211, 178, 0.12) 0%, transparent 60%),
      var(--couleur-surface);
    border-top: 1px solid var(--couleur-bordure);
    border-bottom: 1px solid var(--couleur-bordure);
    padding: var(--padding-section);
  }

  .cta-final__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.5rem;
  }

  .cta-final__titre {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    margin-bottom: 0.75rem;
  }

  .cta-final__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: 1rem;
    max-width: 50ch;
    line-height: 1.7;
  }

  .cta-final__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-final__btn {
    font-size: 1.05rem;
    padding: 1rem 2.5rem;
  }

  .cta-final__tel {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    transition: color 0.2s;
  }

  .cta-final__tel:hover {
    color: var(--couleur-texte);
  }


  /* =====================
     Tablette (≥ 640px)
  ===================== */
  @media (min-width: 640px) {
    .points-forts__grille {
      grid-template-columns: repeat(2, 1fr);
    }
  }


  /* =====================
     Desktop (≥ 900px)
  ===================== */
  @media (min-width: 900px) {
    .hero__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .hero__contenu {
      max-width: 55%;
    }

    .pc__ecran {
      width: 260px;
      height: 175px;
    }

    .pc__pied {
      width: 60px;
      height: 12px;
    }

    .pc__base {
      width: 140px;
    }

