---
/* Page Tarifs — Story 2.4 */
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Tarifs Montage PC Isère | Sefacile PC"
  description="Tarifs clairs pour le montage PC en Isère. PC Gaming dès 800€, Workstation dès 1500€. Devis gratuit sans engagement."
>
  <Header />

  <main>

    <!-- ================================
         1. HERO PAGE
    ================================= -->
    <section class="page-hero">
      <div class="conteneur">
        <h1 class="page-hero__titre">Tarifs</h1>
        <p class="page-hero__sous-titre">
          Des configurations sur-mesure pour chaque budget
        </p>
      </div>
    </section>


    <!-- ================================
         2. GRILLE PC GAMING
    ================================= -->
    <section class="tarifs-section" aria-labelledby="titreGaming">
      <div class="conteneur">

        <div class="section__entete">
          <span class="section__icone" aria-hidden="true">🎮</span>
          <h2 class="section__titre" id="titreGaming">PC Gaming</h2>
          <p class="section__sous-titre">Assemblage sur-mesure pour joueurs</p>
        </div>

        <div class="tarifs__grille">

          <!-- Entrée de gamme -->
          <article class="carte-tarif">
            <div class="carte-tarif__entete">
              <h3 class="carte-tarif__nom">Entrée de gamme</h3>
              <div class="carte-tarif__prix">
                <span class="prix__valeur">800 € – 1 200 €</span>
              </div>
            </div>
            <ul class="carte-tarif__liste">
              <li>Jeux en 1080p, 60 fps stables</li>
              <li>Usage bureautique & web</li>
              <li>Jeux e-sport (Valorant, CS2, Fortnite)</li>
              <li>Composants fiables longue durée</li>
            </ul>
            <a href="/contact" class="carte-tarif__btn btn-secondaire">
              Demander un devis
            </a>
          </article>

          <!-- Milieu de gamme — mis en avant -->
          <article class="carte-tarif carte-tarif--vedette">
            <div class="carte-tarif__badge">⭐ Le plus demandé</div>
            <div class="carte-tarif__entete">
              <h3 class="carte-tarif__nom">Milieu de gamme</h3>
              <div class="carte-tarif__prix">
                <span class="prix__valeur">1 200 € – 2 000 €</span>
              </div>
            </div>
            <ul class="carte-tarif__liste">
              <li>Jeux en 1440p, 144 fps</li>
              <li>Streaming simultané sans perte de perf</li>
              <li>AAA récents en ultra</li>
              <li>Évolutif et pérenne</li>
            </ul>
            <a href="/contact" class="carte-tarif__btn btn-principal">
              Demander un devis
            </a>
          </article>

          <!-- Haut de gamme -->
          <article class="carte-tarif">
            <div class="carte-tarif__entete">
              <h3 class="carte-tarif__nom">Haut de gamme</h3>
              <div class="carte-tarif__prix">
                <span class="prix__valeur">2 000 € – 2 500 €</span>
                <span class="prix__plus">+</span>
              </div>
            </div>
            <ul class="carte-tarif__liste">
              <li>4K gaming, 165 fps+</li>
              <li>Ultra settings sans compromis</li>
              <li>Watercooling & RGB maîtrisé</li>
              <li>Meilleure expérience possible</li>
            </ul>
            <a href="/contact" class="carte-tarif__btn btn-secondaire">
              Demander un devis
            </a>
          </article>

        </div>
      </div>
    </section>


    <!-- ================================
         3. GRILLE WORKSTATION 3D
    ================================= -->
    <section class="tarifs-section tarifs-section--alt" aria-labelledby="titreWorkstation">
      <div class="conteneur">

        <div class="section__entete">
          <span class="section__icone" aria-hidden="true">🖥️</span>
          <h2 class="section__titre" id="titreWorkstation">Workstation 3D</h2>
          <p class="section__sous-titre">Stations de travail pour professionnels</p>
        </div>

        <div class="tarifs__grille">

          <!-- Studio -->
          <article class="carte-tarif">
            <div class="carte-tarif__entete">
              <h3 class="carte-tarif__nom">Studio</h3>
              <div class="carte-tarif__prix">
                <span class="prix__valeur">1 500 € – 2 500 €</span>
              </div>
            </div>
            <ul class="carte-tarif__liste">
              <li>Modélisation 3D (Blender, C4D)</li>
              <li>Montage vidéo HD & Full HD</li>
              <li>Graphisme & illustration</li>
              <li>Idéal indépendants & étudiants</li>
            </ul>
            <a href="/contact" class="carte-tarif__btn btn-secondaire">
              Demander un devis
            </a>
          </article>

          <!-- Professionnel — mis en avant -->
          <article class="carte-tarif carte-tarif--vedette">
            <div class="carte-tarif__badge">⭐ Recommandé</div>
            <div class="carte-tarif__entete">
              <h3 class="carte-tarif__nom">Professionnel</h3>
              <div class="carte-tarif__prix">
                <span class="prix__valeur">2 500 € – 4 000 €</span>
              </div>
            </div>
            <ul class="carte-tarif__liste">
              <li>Rendu 3D GPU accéléré</li>
              <li>Effets visuels & compositing</li>
              <li>Montage & étalonnage vidéo 4K</li>
              <li>RAM ECC optionnelle</li>
            </ul>
            <a href="/contact" class="carte-tarif__btn btn-principal">
              Demander un devis
            </a>
          </article>

          <!-- Expert -->
          <article class="carte-tarif">
            <div class="carte-tarif__entete">
              <h3 class="carte-tarif__nom">Expert</h3>
              <div class="carte-tarif__prix">
                <span class="prix__valeur">4 000 € – 5 000 €</span>
                <span class="prix__plus">+</span>
              </div>
            </div>
            <ul class="carte-tarif__liste">
              <li>Production AAA & VFX</li>
              <li>Simulation physique & IA locale</li>
              <li>CPU Threadripper / GPU Quadro</li>
              <li>Studios de production professionnels</li>
            </ul>
            <a href="/contact" class="carte-tarif__btn btn-secondaire">
              Demander un devis
            </a>
          </article>

        </div>
      </div>
    </section>


    <!-- ================================
         4. MAIN D'ŒUVRE
    ================================= -->
    <section class="main-oeuvre" aria-labelledby="titreMainOeuvre">
      <div class="conteneur">
        <div class="main-oeuvre__encadre">

          <div class="main-oeuvre__gauche">
            <span class="main-oeuvre__icone" aria-hidden="true">🔧</span>
            <div>
              <h2 class="main-oeuvre__titre" id="titreMainOeuvre">Forfait montage</h2>
              <p class="main-oeuvre__prix">80 € – 150 €</p>
              <p class="main-oeuvre__detail">Selon la complexité du build (câble management, watercooling, nombre de composants)</p>
            </div>
          </div>

          <div class="main-oeuvre__mention">
            <span class="mention__icone" aria-hidden="true">ℹ️</span>
            <p>
              Les prix des composants varient selon le marché au moment de la commande.
              <strong> Devis gratuit et sans engagement</strong> — le tarif final est fixé avant tout achat.
            </p>
          </div>

        </div>
      </div>
    </section>


    <!-- ================================
         5. FAQ
    ================================= -->
    <section class="faq" aria-labelledby="titreFaq">
      <div class="conteneur">

        <div class="section__entete">
          <h2 class="section__titre" id="titreFaq">Questions fréquentes</h2>
        </div>

        <dl class="faq__liste">

          <div class="faq__item">
            <dt class="faq__question">
              <button
                class="faq__btn"
                aria-expanded="false"
                aria-controls="faq1"
              >
                Les composants sont-ils garantis ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq1" hidden>
              Oui, tous les composants sont neufs et achetés chez des revendeurs agréés.
              Ils bénéficient de la garantie constructeur complète (2 à 5 ans selon les pièces).
              En cas de défaut, je m'occupe des démarches avec le fournisseur.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button
                class="faq__btn"
                aria-expanded="false"
                aria-controls="faq2"
              >
                Livrez-vous en dehors de l'Isère ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq2" hidden>
              Mon secteur principal est l'Isère (Grenoble, Voiron, Bourgoin-Jallieu et alentours).
              Pour les départements limitrophes, n'hésitez pas à me contacter —
              une livraison sécurisée ou un déplacement peut être envisagé selon la distance.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button
                class="faq__btn"
                aria-expanded="false"
                aria-controls="faq3"
              >
                Combien de temps prend un montage ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq3" hidden>
              Entre 2 et 5 jours ouvrés à partir de la réception des composants.
              Ce délai inclut le montage, les tests de stabilité sur 24 h,
              l'installation de Windows et des drivers. Les builds complexes (watercooling custom)
              peuvent nécessiter un jour supplémentaire.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button
                class="faq__btn"
                aria-expanded="false"
                aria-controls="faq4"
              >
                Puis-je fournir mes propres composants ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq4" hidden>
              Oui, tout à fait. Dans ce cas, seul le forfait montage (80–150 €) s'applique.
              Je vérifie la compatibilité de vos pièces avant de commencer et vous préviens
              si quelque chose pose problème. Notez que je ne peux pas garantir les composants
              que vous fournissez vous-même.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button
                class="faq__btn"
                aria-expanded="false"
                aria-controls="faq5"
              >
                Proposez-vous un SAV après livraison ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq5" hidden>
              Oui. Je reste disponible par téléphone ou email après la remise de votre PC.
              En cas de problème matériel couvert par la garantie constructeur,
              je vous accompagne dans les démarches. Pour un suivi renforcé,
              n'hésitez pas à en parler lors de votre devis.
            </dd>
          </div>

        </dl>

      </div>
    </section>


    <!-- ================================
         6. CTA FINAL
    ================================= -->
    <section class="cta-final" aria-labelledby="titreCtaTarifs">
      <div class="conteneur cta-final__inner">
        <div>
          <h2 class="cta-final__titre" id="titreCtaTarifs">Ces tarifs vous correspondent ?</h2>
          <p class="cta-final__sous-titre">
            Demandez un devis personnalisé — je sélectionne les composants selon votre budget exact.
          </p>
        </div>
        <a href="/contact" class="btn-principal cta-final__btn">
          Demander un devis gratuit
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>


<!-- Script : accordéon FAQ -->
<script>
  document.querySelectorAll<HTMLButtonElement>(".faq__btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const ouvert = btn.getAttribute("aria-expanded") === "true";
      const cibleId = btn.getAttribute("aria-controls");
      const reponse = cibleId ? document.getElementById(cibleId) : null;

      /* Ferme toutes les autres questions */
      document.querySelectorAll<HTMLButtonElement>(".faq__btn").forEach((b) => {
        b.setAttribute("aria-expanded", "false");
        b.closest(".faq__item")?.querySelector(".faq__reponse")?.setAttribute("hidden", "");
      });

      /* Ouvre ou ferme la question cliquée */
      if (!ouvert && reponse) {
        btn.setAttribute("aria-expanded", "true");
        reponse.removeAttribute("hidden");
      }
    });
  });
</script>


<style>
  /* =====================
     Hero page
  ===================== */
  .page-hero {
    padding: 3.5rem 0 3rem;
    text-align: center;
    border-bottom: 1px solid var(--couleur-bordure);
    background: radial-gradient(ellipse 50% 40% at 50% 0%, rgba(230,57,70,0.07) 0%, transparent 70%),
                var(--couleur-fond);
  }

  .page-hero__titre {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    margin-bottom: 0.75rem;
  }

  .page-hero__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: 1rem;
  }

  /* =====================
     En-têtes de section
  ===================== */
  .section__entete {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section__icone {
    display: block;
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .section__titre {
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin-bottom: 0.4rem;
  }

  .section__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: 0.95rem;
  }

  /* =====================
     Sections tarifs
  ===================== */
  .tarifs-section {
    padding: var(--padding-section);
    background-color: var(--couleur-fond);
  }

  .tarifs-section--alt {
    background-color: var(--couleur-surface);
  }

  /* =====================
     Grille de cartes
  ===================== */
  .tarifs__grille {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  /* =====================
     Carte tarif
  ===================== */
  .carte-tarif {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--couleur-surface-2);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
    padding: 1.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .carte-tarif:hover {
    border-color: rgba(230,57,70,0.35);
    transform: translateY(-3px);
  }

  .carte-tarif--vedette {
    border-color: var(--couleur-rouge);
    box-shadow: var(--ombre-rouge);
  }

  .carte-tarif__badge {
    position: absolute;
    top: -13px;
    left: 1.75rem;
    background-color: var(--couleur-rouge);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.8rem;
    border-radius: 999px;
  }

  .carte-tarif__entete {
    margin-bottom: 1.25rem;
  }

  .carte-tarif__nom {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .carte-tarif__prix {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
  }

  .prix__valeur {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--couleur-rouge);
    letter-spacing: -0.02em;
  }

  .prix__plus {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--couleur-rouge);
  }

  /* Liste des caractéristiques */
  .carte-tarif__liste {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
    margin-bottom: 1.75rem;
  }

  .carte-tarif__liste li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.875rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.4;
  }

  .carte-tarif__liste li::before {
    content: "›";
    color: var(--couleur-rouge);
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: -0.05rem;
  }

  .carte-tarif__btn {
    display: block;
    text-align: center;
    margin-top: auto;
  }


  /* =====================
     Main d'œuvre
  ===================== */
  .main-oeuvre {
    padding: 3rem 0;
    background-color: var(--couleur-fond);
    border-top: 1px solid var(--couleur-bordure);
  }

  .main-oeuvre__encadre {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background-color: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-left: 4px solid var(--couleur-rouge);
    border-radius: var(--rayon-grand);
    padding: 2rem;
  }

  .main-oeuvre__gauche {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .main-oeuvre__icone {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .main-oeuvre__titre {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  .main-oeuvre__prix {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--couleur-rouge);
    margin-bottom: 0.3rem;
  }

  .main-oeuvre__detail {
    font-size: 0.85rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.5;
  }

  .main-oeuvre__mention {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background-color: rgba(255,255,255,0.03);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon);
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.6;
  }

  .mention__icone {
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .main-oeuvre__mention strong {
    color: var(--couleur-texte);
  }


  /* =====================
     FAQ
  ===================== */
  .faq {
    padding: var(--padding-section);
    background-color: var(--couleur-surface);
    border-top: 1px solid var(--couleur-bordure);
  }

  .faq__liste {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 760px;
    margin-inline: auto;
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
    overflow: hidden;
  }

  .faq__item {
    border-bottom: 1px solid var(--couleur-bordure);
  }

  .faq__item:last-child {
    border-bottom: none;
  }

  .faq__question {
    /* dt reset */
    margin: 0;
  }

  .faq__btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    color: var(--couleur-texte);
    font-family: var(--police);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .faq__btn:hover {
    background-color: rgba(255,255,255,0.03);
  }

  .faq__btn[aria-expanded="true"] {
    color: var(--couleur-rouge);
  }

  .faq__chevron {
    font-size: 1rem;
    flex-shrink: 0;
    transition: transform 0.25s;
  }

  .faq__btn[aria-expanded="true"] .faq__chevron {
    transform: rotate(180deg);
  }

  .faq__reponse {
    padding: 0 1.5rem 1.25rem;
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.7;
  }

  /* Quand hidden est retiré */
  .faq__reponse:not([hidden]) {
    display: block;
  }


  /* =====================
     CTA final
  ===================== */
  .cta-final {
    padding: var(--padding-section);
    background: linear-gradient(135deg, rgba(230,57,70,0.1) 0%, transparent 60%),
                var(--couleur-fond);
    border-top: 1px solid var(--couleur-bordure);
  }

  .cta-final__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
  }

  .cta-final__titre {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 0.5rem;
  }

  .cta-final__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: 1rem;
    line-height: 1.7;
  }

  .cta-final__btn {
    font-size: 1rem;
    padding: 0.9rem 2.25rem;
    flex-shrink: 0;
  }


  /* =====================
     Tablette (≥ 640px)
  ===================== */
  @media (min-width: 640px) {
    .tarifs__grille {
      grid-template-columns: repeat(3, 1fr);
    }

    .main-oeuvre__encadre {
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }

    .main-oeuvre__mention {
      flex: 1;
    }
  }


  /* =====================
     Desktop (≥ 900px)
  ===================== */
  @media (min-width: 900px) {
    .cta-final__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
