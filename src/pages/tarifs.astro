---
/* Page Tarifs — refonte prestations réelles */
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Tarifs Montage PC Isère | Sefacile PC"
  description="Montage PC sur-mesure à 150 € en Isère. Tu achètes tes composants, je monte, teste et te livre clé en main à Corbelin. Devis gratuit."
>
  <Header />

  <main>

    <!-- ================================
         1. HERO
    ================================= -->
    <section class="page-hero">
      <div class="conteneur">
        <h1 class="page-hero__titre">Des prestations claires,<br />des tarifs honnêtes</h1>
        <p class="page-hero__sous-titre">
          Pas de surprise, pas de marge sur les pièces — tu paies le montage, pas les composants.
        </p>
      </div>
    </section>


    <!-- ================================
         2. PRESTATION PRINCIPALE
    ================================= -->
    <section class="prestations" aria-labelledby="titrePrestations">
      <div class="conteneur">

        <!-- Carte principale : Montage -->
        <article class="carte-principale" aria-labelledby="titreMontage">
          <div class="carte-principale__badge">Notre prestation phare</div>

          <div class="carte-principale__entete">
            <div class="carte-principale__icone" aria-hidden="true">🔧</div>
            <div>
              <h2 class="carte-principale__titre" id="titreMontage">Montage PC sur-mesure</h2>
              <div class="carte-principale__prix">150 <span class="prix__devise">€</span></div>
            </div>
          </div>

          <ul class="inclus">
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Montage complet du PC
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Cable management soigné
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Installation Windows
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Mise à jour système et composants
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Test de stabilité OCCT
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Conseil et validation de ta config avant achat
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Livraison en main propre en Isère
            </li>
          </ul>

          <a href="/contact" class="btn-principal carte-principale__cta">
            Demander un devis gratuit
          </a>

          <p class="carte-principale__mention">
            Le prix des composants n'est pas inclus — tu achètes tes pièces, je m'occupe du reste.
          </p>
        </article>


        <!-- Carte secondaire : Entretien -->
        <article class="carte-secondaire" aria-labelledby="titreEntretien">
          <div class="carte-secondaire__entete">
            <div class="carte-secondaire__icone" aria-hidden="true">🧹</div>
            <div>
              <h2 class="carte-secondaire__titre" id="titreEntretien">Entretien PC</h2>
              <div class="carte-secondaire__prix">À partir de <strong>30 €</strong></div>
            </div>
          </div>

          <ul class="inclus inclus--secondaire">
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Dépoussiérage complet
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Remplacement pâte thermique CPU et GPU
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Nettoyage des ventilateurs
            </li>
            <li class="inclus__item">
              <span class="inclus__coche" aria-hidden="true">✓</span>
              Vérification générale
            </li>
          </ul>

          <p class="carte-secondaire__mention">Tarif selon l'état et le temps nécessaire</p>

          <a href="/contact" class="btn-secondaire carte-secondaire__cta">
            Me contacter
          </a>
        </article>

      </div>
    </section>


    <!-- ================================
         3. COMMENT ÇA MARCHE
    ================================= -->
    <section class="process" aria-labelledby="titreProcess">
      <div class="conteneur">

        <div class="section__entete">
          <h2 class="section__titre" id="titreProcess">Comment ça marche ?</h2>
        </div>

        <ol class="process__etapes">

          <li class="etape">
            <div class="etape__numero" aria-hidden="true">1</div>
            <div class="etape__contenu">
              <h3 class="etape__titre">On discute de ta config</h3>
              <p class="etape__texte">
                Tu m'envoies tes idées ou ton budget,
                je valide ou optimise ta sélection de composants.
              </p>
            </div>
          </li>

          <li class="etape">
            <div class="etape__numero" aria-hidden="true">2</div>
            <div class="etape__contenu">
              <h3 class="etape__titre">Tu achètes tes pièces</h3>
              <p class="etape__texte">
                Une fois la config validée, tu commandes
                tes composants où tu veux au meilleur prix.
              </p>
            </div>
          </li>

          <li class="etape">
            <div class="etape__numero" aria-hidden="true">3</div>
            <div class="etape__contenu">
              <h3 class="etape__titre">Je monte ton PC</h3>
              <p class="etape__texte">
                Tu déposes tes pièces à mon atelier à Corbelin,
                je monte, teste et te livre ton PC clé en main.
              </p>
            </div>
          </li>

        </ol>
      </div>
    </section>


    <!-- ================================
         4. FAQ
    ================================= -->
    <section class="faq" aria-labelledby="titreFaq">
      <div class="conteneur">

        <div class="section__entete">
          <h2 class="section__titre" id="titreFaq">Questions fréquentes</h2>
        </div>

        <dl class="faq__liste">

          <div class="faq__item">
            <dt class="faq__question">
              <button class="faq__btn" aria-expanded="false" aria-controls="faq1">
                Est-ce que vous vendez les composants ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq1" hidden>
              Non, Sefacile PC propose uniquement le montage et le conseil.
              Tu achètes tes pièces où tu veux, ce qui te garantit
              les meilleurs prix du marché et la garantie constructeur à ton nom.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button class="faq__btn" aria-expanded="false" aria-controls="faq2">
                Combien de temps prend un montage ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq2" hidden>
              En général 1 à 2 jours selon la complexité de la configuration.
              Ce délai inclut le montage, les tests de stabilité OCCT,
              l'installation de Windows et des drivers.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button class="faq__btn" aria-expanded="false" aria-controls="faq3">
                Vous intervenez où ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq3" hidden>
              Je suis basé à Corbelin en Isère. Tu déposes tes pièces à l'atelier
              et je te livre en main propre. Je couvre Grenoble, Voiron,
              Bourgoin-Jallieu et les communes alentour.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button class="faq__btn" aria-expanded="false" aria-controls="faq4">
                Est-ce que vous pouvez m'aider à choisir mes composants ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq4" hidden>
              Oui ! C'est même inclus dans la prestation.
              Je valide ta config avant que tu achètes pour éviter
              les erreurs de compatibilité et t'assurer le meilleur rapport qualité/prix.
            </dd>
          </div>

          <div class="faq__item">
            <dt class="faq__question">
              <button class="faq__btn" aria-expanded="false" aria-controls="faq5">
                Que se passe-t-il si une pièce est défectueuse ?
                <span class="faq__chevron" aria-hidden="true">▾</span>
              </button>
            </dt>
            <dd class="faq__reponse" id="faq5" hidden>
              Les composants sont sous garantie constructeur à ton nom.
              Je t'accompagne dans les démarches SAV si besoin.
            </dd>
          </div>

        </dl>
      </div>
    </section>


    <!-- ================================
         5. CTA FINAL
    ================================= -->
    <section class="cta-final" aria-labelledby="titreCtaTarifs">
      <div class="conteneur cta-final__inner">
        <div>
          <h2 class="cta-final__titre" id="titreCtaTarifs">Un projet en tête ?</h2>
          <p class="cta-final__sous-titre">
            Dis-moi ce que tu veux faire — je te réponds sous 24 h avec un conseil personnalisé, sans engagement.
          </p>
        </div>
        <a href="/contact" class="btn-principal cta-final__btn">
          Discutons de ton projet
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>


<!-- Script : accordéon FAQ -->
<script>
  document.querySelectorAll<HTMLButtonElement>(".faq__btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const ouvert = btn.getAttribute("aria-expanded") === "true";
      const cibleId = btn.getAttribute("aria-controls");
      const reponse = cibleId ? document.getElementById(cibleId) : null;

      /* Ferme toutes les autres questions */
      document.querySelectorAll<HTMLButtonElement>(".faq__btn").forEach((b) => {
        b.setAttribute("aria-expanded", "false");
        b.closest(".faq__item")?.querySelector(".faq__reponse")?.setAttribute("hidden", "");
      });

      /* Ouvre ou ferme la question cliquée */
      if (!ouvert && reponse) {
        btn.setAttribute("aria-expanded", "true");
        reponse.removeAttribute("hidden");
      }
    });
  });
</script>


<style>
  /* =====================
     Hero page
  ===================== */
  .page-hero {
    padding: 3.5rem 0 3rem;
    text-align: center;
    border-bottom: 1px solid var(--couleur-bordure);
    background: radial-gradient(ellipse 50% 40% at 50% 0%, rgba(13,211,178,0.07) 0%, transparent 70%),
                var(--couleur-fond);
  }

  .page-hero__titre {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .page-hero__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: 1rem;
    max-width: 50ch;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* =====================
     En-têtes de section
  ===================== */
  .section__entete {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section__titre {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
  }


  /* =====================
     Section prestations
  ===================== */
  .prestations {
    padding: var(--padding-section);
    background-color: var(--couleur-fond);
  }

  /* =====================
     Carte principale
  ===================== */
  .carte-principale {
    position: relative;
    background-color: var(--couleur-surface);
    border: 2px solid rgba(13, 211, 178, 0.5);
    border-radius: var(--rayon-grand);
    padding: 2.5rem 2rem;
    box-shadow: var(--ombre-rouge);
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .carte-principale__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--couleur-rouge);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 1.1rem;
    border-radius: 999px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .carte-principale__entete {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
  }

  .carte-principale__icone {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .carte-principale__titre {
    font-size: clamp(1.3rem, 3vw, 1.6rem);
    font-weight: 800;
    margin-bottom: 0.4rem;
  }

  .carte-principale__prix {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--couleur-rouge);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .prix__devise {
    font-size: 1.4rem;
    font-weight: 700;
  }

  .carte-principale__cta {
    display: block;
    width: 100%;
    text-align: center;
    font-size: 1rem;
    padding: 0.95rem;
    margin-top: 1.75rem;
  }

  .carte-principale__mention {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--couleur-texte-secondaire);
    text-align: center;
    font-style: italic;
  }

  /* =====================
     Carte secondaire
  ===================== */
  .carte-secondaire {
    background-color: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
    padding: 1.75rem;
    max-width: 640px;
    margin-inline: auto;
  }

  .carte-secondaire__entete {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .carte-secondaire__icone {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .carte-secondaire__titre {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .carte-secondaire__prix {
    font-size: 0.95rem;
    color: var(--couleur-texte-secondaire);
  }

  .carte-secondaire__prix strong {
    color: var(--couleur-texte);
    font-size: 1.1rem;
  }

  .carte-secondaire__mention {
    font-size: 0.8rem;
    color: var(--couleur-texte-secondaire);
    font-style: italic;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .carte-secondaire__cta {
    display: inline-block;
  }

  /* =====================
     Liste inclus
  ===================== */
  .inclus {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .inclus--secondaire {
    gap: 0.55rem;
  }

  .inclus__item {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.95rem;
    color: var(--couleur-texte);
    line-height: 1.5;
  }

  .inclus--secondaire .inclus__item {
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
  }

  .inclus__coche {
    color: var(--couleur-rouge);
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }


  /* =====================
     Section "Comment ça marche"
  ===================== */
  .process {
    padding: var(--padding-section);
    background-color: var(--couleur-surface);
    border-top: 1px solid var(--couleur-bordure);
  }

  .process__etapes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 640px;
    margin-inline: auto;
  }

  .etape {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .etape__numero {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--couleur-rouge);
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
  }

  .etape__titre {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .etape__texte {
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.6;
  }


  /* =====================
     FAQ
  ===================== */
  .faq {
    padding: var(--padding-section);
    background-color: var(--couleur-fond);
    border-top: 1px solid var(--couleur-bordure);
  }

  .faq__liste {
    max-width: 680px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq__item {
    background-color: var(--couleur-surface);
    border: 1px solid var(--couleur-bordure);
    border-radius: var(--rayon-grand);
    overflow: hidden;
  }

  .faq__question {
    margin: 0;
  }

  .faq__btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    background: transparent;
    border: none;
    color: var(--couleur-texte);
    font-family: var(--police);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    transition: color 0.2s;
  }

  .faq__btn:hover {
    color: var(--couleur-rouge);
  }

  .faq__btn[aria-expanded="true"] {
    color: var(--couleur-rouge);
  }

  .faq__chevron {
    flex-shrink: 0;
    font-size: 1rem;
    transition: transform 0.2s;
  }

  .faq__btn[aria-expanded="true"] .faq__chevron {
    transform: rotate(180deg);
  }

  .faq__reponse {
    padding: 0 1.5rem 1.1rem;
    font-size: 0.9rem;
    color: var(--couleur-texte-secondaire);
    line-height: 1.7;
  }

  /* Empêche display:block d'écraser l'attribut hidden */
  .faq__reponse[hidden] { display: none; }


  /* =====================
     CTA final
  ===================== */
  .cta-final {
    padding: var(--padding-section);
    background: linear-gradient(135deg, rgba(13,211,178,0.1) 0%, transparent 60%),
                var(--couleur-surface);
    border-top: 1px solid var(--couleur-bordure);
  }

  .cta-final__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
  }

  .cta-final__titre {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 0.5rem;
  }

  .cta-final__sous-titre {
    color: var(--couleur-texte-secondaire);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 50ch;
  }

  .cta-final__btn {
    font-size: 1rem;
    padding: 0.9rem 2.25rem;
    flex-shrink: 0;
  }


  /* =====================
     Desktop (≥ 900px)
  ===================== */
  @media (min-width: 900px) {
    .cta-final__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
